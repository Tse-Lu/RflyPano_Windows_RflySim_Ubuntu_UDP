<launch>
  <arg name="input_topic"  default="/panorama/compressed"/>
  <arg name="output_topic" default="/panorama"/>

  <node name="compressed_to_raw" pkg="panoramic_converter" type="compressed_to_raw" output="screen">
    <param name="input_topic"  value="$(arg input_topic)"/>
    <param name="output_topic" value="$(arg output_topic)"/>
  </node>
</launch>
